---
import Layout from "../layouts/Layout.astro";
import { supabase, getPostImageUrl, type Post } from "../lib/supabase";

// Lee posts publicados de la vista publica de BD.
// Si la vista no existe (migracion no aplicada) o hay error, se
// muestra el placeholder de "sin posts" en vez de fallback — asi
// el problema se ve claro en vez de mostrar contenido antiguo.
let posts: Array<Pick<Post, "slug" | "title" | "excerpt" | "image" | "category" | "published_at">> = [];
const { data: postsData, error: postsError } = await supabase
    .from("posts_public")
    .select("slug, title, excerpt, image, category, published_at, sort_order")
    .order("sort_order", { ascending: true })
    .order("published_at", { ascending: false });

if (postsError) {
    console.error("Error leyendo posts_public:", postsError.message);
}
posts = postsData ?? [];

function formatDate(iso: string | null): string {
    if (!iso) return "";
    const date = new Date(iso);
    if (isNaN(date.getTime())) return iso; // si es texto legacy "01 MAY 2026"
    return date
        .toLocaleDateString("es-ES", { day: "2-digit", month: "short", year: "numeric" })
        .toUpperCase();
}
---

<Layout
    title="Journal · Procesos y caos ordenado · MADCRY Studio"
    description="Pensamientos, procesos y entre-bastidores del estudio: cómo nacen las piezas, exposiciones, técnica y cultura visual."
    ogType="article"
>
    <header class="pt-52 pb-16 px-6 text-center border-b border-white/10">
        <h1
            class="text-5xl md:text-8xl font-bold uppercase tracking-tighter text-white mb-4"
        >
            The Journal
        </h1>
        <p
            class="text-gray-500 text-xs md:text-sm tracking-[0.3em] uppercase max-w-2xl mx-auto"
        >
            Pensamientos, procesos y caos ordenado.
        </p>
    </header>

    <section class="max-w-7xl mx-auto px-6 py-20">
        {posts.length === 0 && (
            <p class="text-center text-gray-500 text-xs uppercase tracking-widest py-20">
                Aún no hay posts publicados.
            </p>
        )}
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16"
        >
            {posts.map((post) => (
                <a
                    href={`/blog/${post.slug}`}
                    class="group block cursor-pointer"
                >
                    <div class="overflow-hidden mb-6 border border-white/5 relative aspect-square bg-black flex flex-col items-center justify-center group-hover:border-white/20 transition-colors duration-500">
                        <div class="absolute inset-0 bg-black/40 group-hover:bg-transparent transition duration-500 z-10" />
                        <img
                            src={getPostImageUrl(post.image)}
                            alt={post.title}
                            transition:name={`post-img-${post.slug}`}
                            class="w-full h-full object-contain filter drop-shadow-2xl transition-transform duration-700 group-hover:scale-105"
                        />
                    </div>

                    <div class="flex items-center gap-4 text-[10px] uppercase tracking-widest text-gray-500 mb-3">
                        <span class="group-hover:text-white transition">
                            {formatDate(post.published_at)}
                        </span>
                        {post.category && (
                            <>
                                <span class="w-8 h-[1px] bg-gray-700" />
                                <span class="group-hover:text-white transition">
                                    {post.category}
                                </span>
                            </>
                        )}
                    </div>

                    <h2 class="text-2xl text-white font-bold uppercase leading-tight mb-3 group-hover:text-gray-300 transition">
                        {post.title}
                    </h2>
                    <p class="text-gray-500 text-sm leading-relaxed line-clamp-3 font-sans group-hover:text-gray-400 transition">
                        {post.excerpt}
                    </p>

                    <div class="mt-6">
                        <span class="text-[10px] uppercase tracking-[0.2em] text-white border-b border-white/30 pb-1 group-hover:border-white transition">
                            Leer Artículo
                        </span>
                    </div>
                </a>
            ))}
        </div>
    </section>
</Layout>
