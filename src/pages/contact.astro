---
import Layout from "../layouts/Layout.astro";
---

<Layout title="MADCRY STUDIO | Contacto">
    <main class="min-h-screen pt-52 pb-24 px-6 max-w-7xl mx-auto">
        <div class="flex flex-col lg:flex-row gap-16 lg:gap-32">
            <div class="lg:w-5/12 lg:h-fit lg:sticky lg:top-32 space-y-12">
                <div class="space-y-4">
                    <p
                        class="text-xs font-bold text-gray-500 uppercase tracking-[0.3em] flex items-center gap-2"
                    >
                        <span
                            class="w-2 h-2 bg-green-500 rounded-full animate-pulse"
                        ></span>
                        Open for Business
                    </p>
                    <h1
                        class="text-5xl md:text-7xl font-bold uppercase tracking-tighter text-white leading-[0.9]"
                    >
                        Comencemos<br />tu proyecto
                    </h1>
                </div>

                <div
                    class="text-sm text-gray-400 font-light leading-relaxed max-w-sm space-y-6"
                >
                    <p>
                        Para comisiones privadas o colaboraciones de marca.
                        Cuéntame tu idea y veamos cómo hacerla brillar.
                    </p>
                    <p class="italic text-gray-600">
                        *Actualmente aceptando pedidos para el Q2 2026.
                    </p>
                </div>

                <div
                    class="grid grid-cols-2 gap-8 pt-8 border-t border-white/10"
                >
                    <div>
                        <h3
                            class="text-[10px] text-white uppercase tracking-widest mb-2 font-bold"
                        >
                            Contacto
                        </h3>
                        <a
                            href="mailto:info@madcry.com"
                            class="block text-gray-400 hover:text-white transition text-sm"
                            >info@madcry.com</a
                        >
                        <a
                            href="tel:+34684123159"
                            class="block text-gray-400 hover:text-white transition text-sm mt-1"
                            >+34 684 123 159</a
                        >
                    </div>
                    <div>
                        <h3
                            class="text-[10px] text-white uppercase tracking-widest mb-2 font-bold"
                        >
                            Studio
                        </h3>
                        <p class="text-gray-400 text-sm">Madrid, Spain</p>
                    </div>

                    <div class="col-span-2 flex gap-4 mt-2">
                        <a
                            href="#"
                            class="text-[10px] uppercase tracking-widest text-gray-600 hover:text-white transition"
                            >Instagram</a
                        >
                        <a
                            href="#"
                            class="text-[10px] uppercase tracking-widest text-gray-600 hover:text-white transition"
                            >Twitter / X</a
                        >
                    </div>
                </div>
            </div>

            <div class="lg:w-7/12 pt-4">
                <form
                    id="contact-form"
                    class="space-y-12"
                >
                    <!-- Honeypot anti-bots: humanos no lo ven, bots lo rellenan -->
                    <input
                        type="text"
                        name="honeypot"
                        tabindex="-1"
                        autocomplete="off"
                        class="absolute opacity-0 pointer-events-none h-0 w-0 overflow-hidden"
                        aria-hidden="true"
                    />

                    <div class="space-y-4">
                        <label
                            class="text-[10px] uppercase tracking-widest text-gray-500"
                            >¿Qué tienes en mente?</label
                        >
                        <div class="flex flex-wrap gap-4">
                            <label class="cursor-pointer relative group">
                                <input
                                    type="radio"
                                    name="type"
                                    value="general"
                                    class="peer sr-only"
                                    checked
                                />
                                <span
                                    class="block border border-white/20 px-6 py-3 text-xs uppercase tracking-widest text-gray-400 peer-checked:bg-white peer-checked:text-black peer-checked:border-white transition-all group-hover:border-white/50"
                                >
                                    General
                                </span>
                            </label>
                            <label class="cursor-pointer relative group">
                                <input
                                    type="radio"
                                    name="type"
                                    value="commission"
                                    class="peer sr-only"
                                />
                                <span
                                    class="block border border-white/20 px-6 py-3 text-xs uppercase tracking-widest text-gray-400 peer-checked:bg-white peer-checked:text-black peer-checked:border-white transition-all group-hover:border-white/50"
                                >
                                    Comisión de Arte
                                </span>
                            </label>
                            <label class="cursor-pointer relative group">
                                <input
                                    type="radio"
                                    name="type"
                                    value="collab"
                                    class="peer sr-only"
                                />
                                <span
                                    class="block border border-white/20 px-6 py-3 text-xs uppercase tracking-widest text-gray-400 peer-checked:bg-white peer-checked:text-black peer-checked:border-white transition-all group-hover:border-white/50"
                                >
                                    Colaboración
                                </span>
                            </label>
                        </div>
                    </div>

                    <div
                        class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-12"
                    >
                        <div class="group relative">
                            <input
                                type="text"
                                id="name"
                                name="name"
                                required
                                class="peer block w-full bg-transparent border-b border-white/20 py-4 text-white text-lg outline-none focus:border-white transition-all placeholder-transparent"
                                placeholder="Nombre"
                            />
                            <label
                                for="name"
                                class="absolute left-0 top-4 text-xs uppercase tracking-widest text-gray-500 transition-all pointer-events-none
                                peer-focus:-top-2 peer-focus:text-[10px] peer-focus:text-white
                                peer-[:not(:placeholder-shown)]:-top-2 peer-[:not(:placeholder-shown)]:text-[10px] peer-[:not(:placeholder-shown)]:text-white"
                            >
                                Tu Nombre *
                            </label>
                        </div>

                        <div class="group relative">
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                                class="peer block w-full bg-transparent border-b border-white/20 py-4 text-white text-lg outline-none focus:border-white transition-all placeholder-transparent"
                                placeholder="Email"
                            />
                            <label
                                for="email"
                                class="absolute left-0 top-4 text-xs uppercase tracking-widest text-gray-500 transition-all pointer-events-none
                                peer-focus:-top-2 peer-focus:text-[10px] peer-focus:text-white
                                peer-[:not(:placeholder-shown)]:-top-2 peer-[:not(:placeholder-shown)]:text-[10px] peer-[:not(:placeholder-shown)]:text-white"
                            >
                                Email *
                            </label>
                        </div>

                        <div class="group relative md:col-span-2">
                            <input
                                type="text"
                                id="budget"
                                name="budget"
                                class="peer block w-full bg-transparent border-b border-white/20 py-4 text-white text-lg outline-none focus:border-white transition-all placeholder-transparent"
                                placeholder="Presupuesto"
                            />
                            <label
                                for="budget"
                                class="absolute left-0 top-4 text-xs uppercase tracking-widest text-gray-500 transition-all pointer-events-none
                                peer-focus:-top-2 peer-focus:text-[10px] peer-focus:text-white
                                peer-[:not(:placeholder-shown)]:-top-2 peer-[:not(:placeholder-shown)]:text-[10px] peer-[:not(:placeholder-shown)]:text-white"
                            >
                                Presupuesto Aproximado (Opcional)
                            </label>
                        </div>

                        <div class="group relative md:col-span-2">
                            <textarea
                                id="message"
                                name="message"
                                rows="4"
                                required
                                class="peer block w-full bg-transparent border-b border-white/20 py-4 text-white text-lg outline-none focus:border-white transition-all placeholder-transparent resize-none"
                                placeholder="Mensaje"></textarea>
                            <label
                                for="message"
                                class="absolute left-0 top-4 text-xs uppercase tracking-widest text-gray-500 transition-all pointer-events-none
                                peer-focus:-top-2 peer-focus:text-[10px] peer-focus:text-white
                                peer-[:not(:placeholder-shown)]:-top-2 peer-[:not(:placeholder-shown)]:text-[10px] peer-[:not(:placeholder-shown)]:text-white"
                            >
                                Cuéntame sobre el proyecto *
                            </label>
                        </div>
                    </div>

                    <div
                        class="pt-6 flex flex-col md:flex-row items-center justify-between gap-6"
                    >
                        <button
                            type="submit"
                            class="group relative px-12 py-5 bg-white text-black font-bold uppercase tracking-[0.2em] text-sm overflow-hidden transition-all hover:bg-gray-200 w-full md:w-auto"
                        >
                            <span
                                class="relative z-10 flex items-center justify-center gap-2"
                            >
                                Enviar Mensaje <span>→</span>
                            </span>
                        </button>

                        <p
                            class="text-[10px] text-gray-600 uppercase tracking-widest"
                        >
                            Al enviar aceptas nuestra política de privacidad.
                        </p>
                    </div>

                    <div
                        id="form-status"
                        class="hidden p-4 bg-green-900/20 border border-green-900 text-green-400 text-xs uppercase tracking-widest text-center"
                    >
                        ✓ Mensaje recibido. Nos pondremos en contacto pronto.
                    </div>
                </form>
            </div>
        </div>
    </main>
</Layout>

<script>
    const form = document.getElementById("contact-form");
    const status = document.getElementById("form-status");
    const btn = form?.querySelector("button");
    const btnText = btn?.querySelector("span");

    if (form && btn && btnText) {
        // Guardamos los nodos originales (texto + flecha) de forma segura
        // sin innerHTML para no romper CSP estricta.
        const originalNodes = Array.from(btnText.childNodes).map((n) =>
            n.cloneNode(true),
        );
        const restoreOriginal = () => {
            btnText.replaceChildren(
                ...originalNodes.map((n) => n.cloneNode(true)),
            );
        };

        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            btnText.textContent = "ENVIANDO...";
            btn.disabled = true;
            btn.classList.add("opacity-70", "cursor-not-allowed");

            const formData = new FormData(form as HTMLFormElement);
            const payload = {
                type: formData.get("type") as string,
                name: formData.get("name") as string,
                email: formData.get("email") as string,
                budget: formData.get("budget") as string,
                message: formData.get("message") as string,
                honeypot: formData.get("honeypot") as string,
            };

            try {
                const url = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/send-contact-email`;
                const response = await fetch(url, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        Authorization: `Bearer ${import.meta.env.PUBLIC_SUPABASE_ANON_KEY}`,
                    },
                    body: JSON.stringify(payload),
                });

                if (!response.ok) {
                    const err = await response.json().catch(() => ({}));
                    throw new Error(err.error || "Error de envio");
                }

                if (status) {
                    status.classList.remove("hidden");
                    status.scrollIntoView({
                        behavior: "smooth",
                        block: "center",
                    });
                }
                (form as HTMLFormElement).reset();
                btnText.textContent = "ENVIADO";

                setTimeout(() => {
                    restoreOriginal();
                    btn.disabled = false;
                    btn.classList.remove("opacity-70", "cursor-not-allowed");
                    if (status) status.classList.add("hidden");
                }, 4000);
            } catch (error) {
                console.error("Contact error:", error);
                btnText.textContent = "ERROR AL ENVIAR";
                setTimeout(() => {
                    restoreOriginal();
                    btn.disabled = false;
                    btn.classList.remove("opacity-70", "cursor-not-allowed");
                }, 4000);
            }
        });
    }

    // El CSS peer-[:not(:placeholder-shown)] ahora maneja el estado de los labels automáticamente.
    // Ya no es necesario el script para remover placeholder-transparent.
</script>
