---
import Layout from "../../layouts/Layout.astro";
import { supabase, formatPrice, getProductImageUrl, type Product } from "../../lib/supabase";

export async function getStaticPaths() {
    const { data } = await supabase
        .from("products_public")
        .select("*");

    if (!data) return [];

    return data.map((product) => ({
        params: { slug: product.slug },
        props: { product },
    }));
}

const { product } = Astro.props as { product: Product & {
    category_price_label?: string | null;
    category_default_description?: string | null;
    category_hide_price?: boolean | null;
    reveal_at?: string | null;
    is_locked?: boolean | null;
}};
const isLocked = !!product.is_locked;
const revealAt = product.reveal_at ?? null;
const mainImage = isLocked
    ? "/images/mystery-card.png"
    : Array.isArray(product.images) && product.images.length > 0
      ? getProductImageUrl(String(product.images[0]))
      : "/images/logo.png";
const hidePrice = !!product.category_hide_price;
const priceLabel = product.category_price_label || "Commission";
const fallbackDescription = product.category_default_description || "Pieza unica de la coleccion.";
const contactUrl = `/contact?type=commission&product=${encodeURIComponent(product.slug)}`;

const SITE = "https://madcry.com";
const productUrl = `${SITE}/product/${product.slug}`;
const absoluteImage = mainImage.startsWith("http") ? mainImage : `${SITE}${mainImage}`;
const availability =
    product.status === "available"
        ? "https://schema.org/InStock"
        : product.status === "reserved"
          ? "https://schema.org/PreOrder"
          : "https://schema.org/SoldOut";

const productSchema: Record<string, unknown> = {
    "@context": "https://schema.org",
    "@type": "Product",
    name: product.name,
    description: product.description || fallbackDescription,
    image: absoluteImage,
    sku: product.id,
    brand: { "@type": "Brand", name: "MADCRY Studio" },
    category: product.category_slug ?? undefined,
};
if (!hidePrice) {
    productSchema.offers = {
        "@type": "Offer",
        url: productUrl,
        priceCurrency: (product.currency || "eur").toUpperCase(),
        price: (product.price_cents / 100).toFixed(2),
        availability,
        itemCondition: "https://schema.org/NewCondition",
        seller: { "@type": "Organization", name: "MADCRY Studio" },
    };
}

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: SITE },
        { "@type": "ListItem", position: 2, name: "Colección", item: `${SITE}/shop` },
        { "@type": "ListItem", position: 3, name: product.name, item: productUrl },
    ],
};
---

<Layout
    title={isLocked ? `Coming Soon · 13.05.2026 · MADCRY Studio` : `${product.name} · MADCRY Studio`}
    description={isLocked
        ? "Coleccion MADCRY · Reveal oficial el 13 de mayo de 2026 a las 20:00 CET. Pieza unica (1/1) pintada a mano por Susana Madriz."
        : product.description || `${product.name}: pieza única (1/1) de Susana Madriz. ${fallbackDescription}`}
    image={mainImage}
    ogType="product"
    noindex={isLocked}
    schema={isLocked ? [breadcrumbSchema] : [productSchema, breadcrumbSchema]}
>
    {isLocked ? (
        <main
            class="min-h-screen flex flex-col items-center justify-center px-6 pt-32 pb-12 md:pb-20 relative overflow-hidden"
            data-locked-page
            data-reveal-at={revealAt ?? ""}
        >
            {/* Back fijo arriba-izquierda, fuera del flujo central. z-30 para
                pasar por encima del nav que tiene z-50 a la altura del logo
                pero deja libre la zona izquierda. */}
            <a
                href="/shop"
                class="fixed top-20 md:top-24 left-4 md:left-8 z-40 inline-flex items-center gap-1.5 text-[9px] md:text-[10px] uppercase tracking-[0.25em] md:tracking-[0.3em] text-gray-500 hover:text-white border border-white/10 hover:border-white/40 bg-black/60 backdrop-blur-sm px-3 py-2 transition"
            >
                ← Back
            </a>

            {/* Marca de agua "M" gigante de fondo */}
            <div
                class="absolute inset-0 pointer-events-none opacity-[0.04] flex items-center justify-center select-none"
            >
                <span class="text-[40vw] font-bold uppercase tracking-tighter leading-[0.8]"
                    >M</span
                >
            </div>

            {/* Contenido central — gaps mas ajustados en mobile para que
                todo entre en pantallas pequenas sin scroll forzado */}
            <div class="relative z-10 max-w-3xl w-full text-center space-y-6 md:space-y-10">
                <div class="space-y-1 md:space-y-2 animate-pulse">
                    <p class="text-red-500 text-[10px] tracking-[0.5em] font-bold uppercase">
                        Pieza protegida
                    </p>
                    <p class="text-red-500/70 text-[10px] tracking-[0.5em] font-bold uppercase">
                        Coleccion MADCRY
                    </p>
                </div>

                <h1
                    class="text-5xl md:text-8xl font-bold uppercase tracking-tighter text-white leading-[0.9]"
                >
                    Coming<br />Soon
                </h1>

                <div class="text-gray-400 text-[11px] md:text-sm tracking-[0.25em] md:tracking-[0.3em] uppercase max-w-xl mx-auto leading-relaxed space-y-1 md:space-y-2">
                    <p>Esta pieza no se revela</p>
                    <p>hasta la apertura oficial de la exposicion</p>
                    <p class="text-white pt-1">13 de mayo de 2026 · 20:00</p>
                </div>

                <div class="flex flex-col items-center gap-3 md:gap-5 pt-2">
                    <span class="text-[10px] tracking-[0.4em] uppercase text-gray-500">Reveal en</span>
                    <div
                        class="grid grid-cols-4 gap-4 md:gap-12"
                        data-locked-countdown
                    >
                        <div class="flex flex-col items-center">
                            <span class="text-3xl md:text-7xl font-bold text-white tabular-nums leading-none" data-cd="d">—</span>
                            <span class="text-[9px] md:text-xs tracking-[0.3em] uppercase text-gray-500 mt-2 md:mt-3">Days</span>
                        </div>
                        <div class="flex flex-col items-center">
                            <span class="text-3xl md:text-7xl font-bold text-white tabular-nums leading-none" data-cd="h">—</span>
                            <span class="text-[9px] md:text-xs tracking-[0.3em] uppercase text-gray-500 mt-2 md:mt-3">Hours</span>
                        </div>
                        <div class="flex flex-col items-center">
                            <span class="text-3xl md:text-7xl font-bold text-white tabular-nums leading-none" data-cd="m">—</span>
                            <span class="text-[9px] md:text-xs tracking-[0.3em] uppercase text-gray-500 mt-2 md:mt-3">Min</span>
                        </div>
                        <div class="flex flex-col items-center">
                            <span class="text-3xl md:text-7xl font-bold text-white tabular-nums leading-none" data-cd="s">—</span>
                            <span class="text-[9px] md:text-xs tracking-[0.3em] uppercase text-gray-500 mt-2 md:mt-3">Sec</span>
                        </div>
                    </div>
                </div>

                <p class="text-[9px] md:text-[10px] text-gray-600 uppercase tracking-[0.3em] pt-2 md:pt-6">
                    Susana Madriz · Madrid · 1/1
                </p>
            </div>
        </main>
    ) : (
    <main class="min-h-screen grid grid-cols-1 lg:grid-cols-2 pt-12">
        <div
            class="h-[50vh] lg:h-screen bg-black flex items-center justify-center p-6 lg:p-0 relative overflow-hidden group"
        >
            <a
                href="/shop"
                class="absolute top-24 left-6 text-white text-[10px] uppercase tracking-widest lg:hidden z-20 border border-white/20 px-3 py-1 bg-black/50 backdrop-blur"
                >Back</a
            >

            <img
                src={mainImage}
                alt={product.name}
                class="lightbox-trigger cursor-zoom-in max-h-[60%] max-w-[90%] object-contain shadow-[0_0_100px_rgba(0,0,0,0.5)] group-hover:scale-[1.02] transition duration-700"
                transition:name={`image-${product.id}`}
            />
        </div>

        <div
            class="h-auto lg:h-screen bg-black flex flex-col justify-center p-8 lg:p-24 border-l border-zinc-900 relative"
        >
            <a
                href="/shop"
                class="hidden lg:inline-block absolute top-32 right-12 text-gray-500 hover:text-white text-[10px] uppercase tracking-[0.3em] transition z-50"
                >← Back to Collection</a
            >

            <div class="mb-auto mt-12 lg:mt-0"></div>

            <h1
                class="text-4xl lg:text-7xl font-bold uppercase mb-4 leading-[0.9] tracking-tighter"
            >
                {product.name}
            </h1>
            {hidePrice ? (
                <p class="text-base text-gray-400 font-light mb-12 tracking-[0.3em] uppercase">
                    {priceLabel} · Presupuesto a medida
                </p>
            ) : product.status === "sold" ? (
                <p class="text-xl text-gray-500 font-light mb-12 tracking-[0.3em] uppercase line-through decoration-1">
                    Sold
                </p>
            ) : (
                <div class="mb-12">
                    <p class="text-2xl text-gray-400 font-light tracking-wider font-mono">
                        {formatPrice(product.price_cents, product.currency || "eur")}
                    </p>
                    {product.price_cents >= 8500 ? (
                        <p class="text-[10px] tracking-[0.4em] uppercase text-green-500 mt-2 flex items-center gap-2">
                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                            Envío gratis incluido
                        </p>
                    ) : (
                        <p class="text-[10px] tracking-[0.4em] uppercase text-gray-500 mt-2">
                            + 10€ envío España · Gratis a partir de 85€
                        </p>
                    )}
                </div>
            )}

            <div
                class="space-y-6 text-gray-400 text-sm tracking-wide leading-relaxed mb-16 border-t border-white/10 pt-8 max-w-md"
            >
                <p>{product.description || fallbackDescription}</p>
                <ul
                    class="space-y-2 text-xs uppercase tracking-widest text-gray-500 list-disc list-inside"
                >
                    <li>
                        Estado: <span data-status-text>{product.status === "sold" ? "Vendido" : "Disponible"}</span>
                    </li>
                    {product.dimensions && <li>Dimensiones: {product.dimensions}</li>}
                    {product.technique && <li>Tecnica: {product.technique}</li>}
                    {product.year_created && <li>Ano: {product.year_created}</li>}
                </ul>
            </div>

            <div class="mb-auto">
                {hidePrice ? (
                    <a
                        href={contactUrl}
                        class="block w-full text-center py-5 text-sm font-bold uppercase tracking-[0.3em] bg-white text-black hover:bg-gray-300 transition duration-300"
                    >
                        Solicitar presupuesto →
                    </a>
                ) : (
                    <button
                        id="buy-btn"
                        data-product-id={product.id}
                        data-status={product.status}
                        class:list={[
                            "w-full text-center py-5 text-sm font-bold uppercase tracking-[0.3em] transition duration-300",
                            product.status === "available"
                                ? "bg-white text-black hover:bg-gray-300 cursor-pointer"
                                : "border border-red-900/30 bg-red-900/10 text-red-500 cursor-not-allowed",
                        ]}
                        disabled={product.status !== "available"}
                    >
                        {product.status === "available" ? "Adquirir Obra" : "Sold Out"}
                    </button>
                )}
                <p id="buy-error" class="text-red-500 text-xs mt-3 text-center hidden"></p>
            </div>
        </div>
    </main>
    )}
</Layout>

<script>
    import { supabase } from "../../lib/supabase";

    function startLockedCountdown() {
        const main = document.querySelector<HTMLElement>("[data-locked-page]");
        if (!main) return;
        const target = main.dataset.revealAt;
        const wrap = main.querySelector<HTMLElement>("[data-locked-countdown]");
        if (!target || !wrap) return;

        const cells = {
            d: wrap.querySelector<HTMLElement>('[data-cd="d"]'),
            h: wrap.querySelector<HTMLElement>('[data-cd="h"]'),
            m: wrap.querySelector<HTMLElement>('[data-cd="m"]'),
            s: wrap.querySelector<HTMLElement>('[data-cd="s"]'),
        };

        const t = new Date(target).getTime();
        const update = () => {
            const diff = t - Date.now();
            if (diff <= 0) {
                if (cells.d) cells.d.textContent = "00";
                if (cells.h) cells.h.textContent = "00";
                if (cells.m) cells.m.textContent = "00";
                if (cells.s) cells.s.textContent = "LIVE";
                setTimeout(() => location.reload(), 1500);
                return;
            }
            const d = Math.floor(diff / 86400000);
            const h = Math.floor((diff % 86400000) / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);
            if (cells.d) cells.d.textContent = String(d).padStart(2, "0");
            if (cells.h) cells.h.textContent = String(h).padStart(2, "0");
            if (cells.m) cells.m.textContent = String(m).padStart(2, "0");
            if (cells.s) cells.s.textContent = String(s).padStart(2, "0");
        };

        update();
        const id = window.setInterval(update, 1000);
        document.addEventListener("astro:before-swap", () => clearInterval(id), { once: true });
    }

    document.addEventListener("astro:page-load", async () => {
        startLockedCountdown();
        const btn = document.getElementById("buy-btn") as HTMLButtonElement | null;
        if (!btn) return;
        const productId = btn.dataset.productId;
        if (!productId) return;

        // Refresh stock — por si Susana lo marco como vendido entre build y carga
        try {
            const { data } = await supabase
                .from("products_public")
                .select("status")
                .eq("id", productId)
                .single();
            if (data && data.status !== btn.dataset.status) {
                location.reload();
            }
        } catch {}

        btn.addEventListener("click", async () => {
            if (btn.disabled) return;
            const original = btn.textContent;
            btn.disabled = true;
            btn.textContent = "Preparando pago...";
            const errEl = document.getElementById("buy-error");
            if (errEl) errEl.classList.add("hidden");

            try {
                const url = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/create-checkout-session`;
                const res = await fetch(url, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        Authorization: `Bearer ${import.meta.env.PUBLIC_SUPABASE_ANON_KEY}`,
                    },
                    body: JSON.stringify({ product_id: productId }),
                });

                const json = await res.json();
                if (!res.ok || !json.url) {
                    throw new Error(json.error || "No se pudo iniciar el pago");
                }
                window.location.href = json.url;
            } catch (e) {
                btn.disabled = false;
                btn.textContent = original;
                const message = e instanceof Error ? e.message : "Error";
                if (errEl) {
                    errEl.textContent = message;
                    errEl.classList.remove("hidden");
                }
            }
        });
    });
</script>
