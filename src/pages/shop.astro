---
import Layout from "../layouts/Layout.astro";
import { supabase, formatPrice, getProductImageUrl, type Product } from "../lib/supabase";

// SSG: leer productos en build. Para refrescar stock sin rebuild,
// ver el script al final que hace polling client-side.
//
// Orden: las piezas de venta directa primero (por precio desc),
// luego las Commission (categorias con hide_price=true) al final.
const { data: products, error } = await supabase
    .from("products_public")
    .select("*")
    .order("category_hide_price", { ascending: true, nullsFirst: true })
    .order("price_cents", { ascending: false })
    .order("created_at", { ascending: false });

if (error) {
    console.error("Error cargando productos:", error);
}

const list: Product[] = (products as Product[] | null) ?? [];

const categories = [
    { id: "all", name: "Todo" },
    { id: "madcry", name: "MadCry" },
    { id: "one-piece", name: "One Piece" },
    { id: "dragon-ball", name: "Dragon Ball" },
    { id: "jujutsu-kaisen", name: "Jujutsu Kaisen" },
    { id: "custom", name: "Custom" },
];
---

<Layout title="MADCRY STUDIO | Shop">
    <header
        class="relative w-full min-h-[40vh] flex flex-col justify-end items-center overflow-hidden border-b border-white/10 pt-40 md:pt-52 pb-10 md:pb-12"
    >
        <div class="absolute inset-0 z-0 bg-neutral-900">
            <div
                class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white/5 via-black/0 to-black"
            >
            </div>
        </div>
        <div class="z-10 text-center space-y-4 px-4">
            <p
                id="category-eyebrow"
                class="hidden text-red-500 text-[10px] tracking-[0.5em] uppercase font-bold"
            ></p>
            <h1
                id="shop-title"
                class="text-4xl md:text-8xl font-bold uppercase tracking-tighter text-white leading-none"
            >
                Colección
            </h1>
            <p class="text-gray-400 text-xs tracking-[0.5em] uppercase">
                Piezas exclusivas • 1/1
            </p>
            <a
                id="show-all-link"
                href="/shop"
                class="hidden mt-4 text-[10px] uppercase tracking-widest text-gray-400 hover:text-white border-b border-gray-700 hover:border-white pb-1 transition"
            >
                Ver todas las obras →
            </a>
        </div>
    </header>

    <section class="max-w-7xl mx-auto px-4 py-12 min-h-screen">
        <div
            id="product-grid"
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16"
        >
            {
                list.map((product) => (
                    <article
                        class="product-item group relative flex flex-col gap-4 transition-all duration-500"
                        data-category={product.category_slug}
                        data-product-id={product.id}
                    >
                        <a
                            href={`/product/${product.slug}`}
                            class="block relative aspect-square overflow-hidden bg-black border border-white/5"
                        >
                            <img
                                src={getProductImageUrl(
                                    Array.isArray(product.images) && product.images.length > 0
                                        ? String(product.images[0])
                                        : null
                                )}
                                alt={product.name}
                                loading="lazy"
                                transition:name={`image-${product.id}`}
                                class="w-full h-full object-cover transition-all duration-700 ease-in-out group-hover:scale-110"
                            />

                            {product.status === "available" && (
                                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                                    <span class="border border-white px-6 py-2 text-white text-xs uppercase tracking-[0.2em] backdrop-blur-sm">
                                        Ver Obra
                                    </span>
                                </div>
                            )}
                        </a>

                        <div class="flex justify-between items-start pt-2 relative z-10">
                            <div class="space-y-1">
                                <h3 class="text-xl text-white font-medium uppercase tracking-wide group-hover:text-gray-300 transition flex items-center gap-3 flex-wrap">
                                    {product.name}

                                    {product.status === "sold" && (
                                        <span data-status-badge class="border border-red-900/30 bg-red-900/10 text-red-500 px-2 py-1 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap">
                                            Sold Out
                                        </span>
                                    )}
                                    {product.is_new && (
                                        <span class="bg-red-600 text-white text-[9px] font-bold px-1.5 py-0.5 rounded uppercase tracking-widest whitespace-nowrap animate-pulse shadow-[0_0_8px_rgba(220,38,38,0.8)]">
                                            New
                                        </span>
                                    )}
                                </h3>
                                <p class="text-xs text-gray-500 uppercase tracking-wider line-clamp-1">
                                    {product.description}
                                </p>
                            </div>
                            <div class="text-right">
                                {(product as any).category_hide_price ? (
                                    <span class="block text-sm text-white font-bold tracking-widest uppercase whitespace-nowrap">
                                        {(product as any).category_price_label || "Commission"}
                                    </span>
                                ) : (
                                    <span class="block text-xl text-white font-bold tracking-widest">
                                        {formatPrice(product.price_cents, product.currency || "eur")}
                                    </span>
                                )}
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>

        {list.length === 0 && (
            <div class="text-center py-20">
                <p class="text-gray-500 uppercase tracking-widest">
                    Aun no hay obras publicadas.
                </p>
            </div>
        )}
    </section>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    const CATEGORY_NAMES: Record<string, string> = {
        madcry: "MadCry",
        "one-piece": "One Piece",
        "dragon-ball": "Dragon Ball",
        "jujutsu-kaisen": "Jujutsu Kaisen",
        naruto: "Naruto",
        custom: "Commission",
        otros: "Otros",
    };

    document.addEventListener("astro:page-load", async () => {
        // --- Filtro por categoria desde ?category= ---
        const params = new URLSearchParams(window.location.search);
        const filterCat = params.get("category");
        if (filterCat) {
            const items = document.querySelectorAll<HTMLElement>(".product-item");
            let visibleCount = 0;
            items.forEach((item) => {
                if (item.dataset.category === filterCat) {
                    item.style.display = "";
                    visibleCount++;
                } else {
                    item.style.display = "none";
                }
            });

            // Actualizar header con el nombre de la coleccion
            const eyebrow = document.getElementById("category-eyebrow");
            const title = document.getElementById("shop-title");
            const showAll = document.getElementById("show-all-link");
            const catName = CATEGORY_NAMES[filterCat] || filterCat;
            if (eyebrow) {
                eyebrow.textContent = `Colección ${catName}`;
                eyebrow.classList.remove("hidden");
            }
            if (title) {
                title.textContent = catName.toUpperCase();
            }
            if (showAll) {
                showAll.classList.remove("hidden");
            }

            // Si no hay productos en la categoria, mostrar mensaje
            if (visibleCount === 0) {
                const grid = document.getElementById("product-grid");
                if (grid) {
                    const empty = document.createElement("p");
                    empty.className =
                        "text-gray-500 text-xs uppercase tracking-widest text-center py-20 col-span-full";
                    empty.textContent = "No hay obras en esta colección aún.";
                    grid.appendChild(empty);
                }
            }
        }

        // --- Refresh stock client-side (sin rebuild necesario) ---
        // Si Susana marca un cuadro como sold, se ve aqui en segundos.
        try {
            const { data } = await supabase
                .from("products_public")
                .select("id, status")
                .in("status", ["available", "sold", "reserved"]);

            if (data) {
                document.querySelectorAll<HTMLElement>(".product-item").forEach((el) => {
                    const id = el.dataset.productId;
                    const fresh = data.find((p) => p.id === id);
                    if (!fresh) return;
                    const badge = el.querySelector("[data-status-badge]");

                    if (fresh.status === "sold" && !badge) {
                        const h3 = el.querySelector("h3");
                        if (h3) {
                            const span = document.createElement("span");
                            span.dataset.statusBadge = "true";
                            span.className =
                                "border border-red-900/30 bg-red-900/10 text-red-500 px-2 py-1 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap";
                            span.textContent = "Sold Out";
                            h3.appendChild(span);
                        }
                    } else if (fresh.status === "available" && badge) {
                        badge.remove();
                    }
                });
            }
        } catch (err) {
            console.warn("Stock refresh fallo:", err);
        }
    });
</script>
