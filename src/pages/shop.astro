---
import Layout from "../layouts/Layout.astro";
import { supabase, formatPrice, getProductImageUrl, type Product } from "../lib/supabase";

// SSG: leer productos en build. Para refrescar stock sin rebuild,
// ver el script al final que hace polling client-side.
//
// Orden: las piezas de venta directa primero (por precio desc),
// luego las Commission (categorias con hide_price=true) al final.
const [{ data: products, error }, { data: allCategories }] = await Promise.all([
    supabase
        .from("products_public")
        .select("*")
        .order("category_hide_price", { ascending: true, nullsFirst: true })
        .order("price_cents", { ascending: false })
        .order("created_at", { ascending: false }),
    supabase.from("categories").select("slug, name").order("sort_order"),
]);

if (error) {
    console.error("Error cargando productos:", error);
}

const list: Product[] = (products as Product[] | null) ?? [];

// Mapa slug→nombre para que el JS de filtro pinte el titulo correcto.
const categoryNames: Record<string, string> = Object.fromEntries(
    (allCategories ?? []).map((c) => [c.slug, c.name])
);
---

<Layout
    title="Colección · MADCRY Studio"
    description="Piezas únicas (1/1) pintadas a mano por Susana Madriz: arte urbano dark, anime y comisiones a medida. Envío a toda Europa."
>
    <!--
        Filtro CSS-first: aplica el ?category=X al <html> antes de que
        el body pinte. Asi evitamos el flash de "todas las categorias"
        que aparecia mientras el JS principal cargaba.
    -->
    <script is:inline>
        (function() {
            function applyShopFilter() {
                try {
                    var p = new URLSearchParams(window.location.search);
                    var cat = p.get("category");
                    if (cat) document.documentElement.setAttribute("data-shop-cat", cat);
                    else document.documentElement.removeAttribute("data-shop-cat");
                } catch (e) {}
            }
            applyShopFilter();
            // Re-aplica tras cada navegacion via Astro ViewTransitions.
            document.addEventListener("astro:page-load", applyShopFilter);
            document.addEventListener("astro:after-swap", applyShopFilter);
        })();
    </script>
    <!-- CSS dinamico: una regla por cada categoria de la BD para que
         el filtro funcione tambien con categorias nuevas que cree el admin
         sin tener que tocar este archivo. -->
    <style is:inline set:html={`
        html[data-shop-cat] .product-item { display: none !important; }
        ${(allCategories ?? []).map((c) => `html[data-shop-cat="${c.slug}"] .product-item[data-category="${c.slug}"] { display: flex !important; }`).join("\n        ")}
    `} />

    <!-- Mapa de slug→nombre de categorias generado en build desde la BD,
         consumido por el script que actualiza el header de la coleccion. -->
    <script id="category-names-data" type="application/json" set:html={JSON.stringify(categoryNames)} />

    <header
        class="relative w-full flex flex-col justify-end items-center overflow-hidden border-b border-white/10 pt-32 md:pt-40 pb-6 md:pb-8"
    >
        <div class="absolute inset-0 z-0 bg-neutral-900">
            <div
                class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white/5 via-black/0 to-black"
            >
            </div>
        </div>
        <div class="z-10 text-center space-y-4 px-4">
            <p
                id="category-eyebrow"
                class="hidden text-red-500 text-[10px] tracking-[0.5em] uppercase font-bold"
            ></p>
            <h1
                id="shop-title"
                class="text-4xl md:text-8xl font-bold uppercase tracking-tighter text-white leading-none"
            >
                Colección
            </h1>
            <p class="text-gray-400 text-xs tracking-[0.5em] uppercase">
                Piezas exclusivas • 1/1
            </p>
            <a
                id="show-all-link"
                href="/shop"
                class="hidden mt-4 text-[10px] uppercase tracking-widest text-gray-400 hover:text-white border-b border-gray-700 hover:border-white pb-1 transition"
            >
                Ver todas las obras →
            </a>
        </div>
    </header>

    <section class="max-w-7xl mx-auto px-4 py-12 min-h-screen">
        <div
            id="product-grid"
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16"
        >
            {
                list.map((product, idx) => {
                    const isLocked = !!(product as any).is_locked;
                    const revealAt = (product as any).reveal_at as string | null;
                    const pieceNumber = String(idx + 1).padStart(2, "0");
                    return (
                        <article
                            class="product-item group relative flex flex-col gap-4 transition-all duration-500"
                            data-category={product.category_slug}
                            data-product-id={product.id}
                            data-price={product.price_cents}
                            data-hide-price={(product as any).category_hide_price ? "1" : "0"}
                            data-locked={isLocked ? "1" : "0"}
                            data-reveal-at={revealAt ?? ""}
                        >
                            {isLocked ? (
                                <div class="block relative aspect-square overflow-hidden bg-black border border-white/10">
                                    {/* Fondo limpio con marca de agua sutil — sin imagen "SOON"
                                        para que el countdown sea el protagonista */}
                                    <div
                                        class="absolute inset-0 bg-gradient-to-br from-zinc-900 via-black to-zinc-900"
                                    />
                                    <div
                                        class="absolute inset-0 flex items-center justify-center pointer-events-none select-none opacity-[0.04]"
                                    >
                                        <span class="text-[28rem] font-bold leading-[0.8] text-white">M</span>
                                    </div>
                                    {/* Borde decorativo con esquinas en rojo */}
                                    <div class="absolute inset-4 border border-white/10 pointer-events-none"></div>
                                    <span class="absolute top-3 left-3 text-[8px] tracking-[0.3em] uppercase text-gray-600 font-bold">
                                        Madcry
                                    </span>
                                    <span class="absolute top-3 right-3 text-[8px] tracking-[0.3em] uppercase text-red-500 font-bold animate-pulse">
                                        ● Coming
                                    </span>

                                    <div class="absolute inset-0 flex flex-col items-center justify-center gap-5 pointer-events-none px-4">
                                        <div
                                            class="grid grid-cols-4 gap-3 md:gap-4 text-center"
                                            data-countdown
                                        >
                                            <div class="flex flex-col items-center">
                                                <span class="text-2xl md:text-3xl font-bold text-white tabular-nums leading-none" data-cd="d">—</span>
                                                <span class="text-[8px] tracking-[0.3em] uppercase text-gray-500 mt-2">Days</span>
                                            </div>
                                            <div class="flex flex-col items-center">
                                                <span class="text-2xl md:text-3xl font-bold text-white tabular-nums leading-none" data-cd="h">—</span>
                                                <span class="text-[8px] tracking-[0.3em] uppercase text-gray-500 mt-2">Hours</span>
                                            </div>
                                            <div class="flex flex-col items-center">
                                                <span class="text-2xl md:text-3xl font-bold text-white tabular-nums leading-none" data-cd="m">—</span>
                                                <span class="text-[8px] tracking-[0.3em] uppercase text-gray-500 mt-2">Min</span>
                                            </div>
                                            <div class="flex flex-col items-center">
                                                <span class="text-2xl md:text-3xl font-bold text-white tabular-nums leading-none" data-cd="s">—</span>
                                                <span class="text-[8px] tracking-[0.3em] uppercase text-gray-500 mt-2">Sec</span>
                                            </div>
                                        </div>
                                        <span class="text-[9px] tracking-[0.4em] uppercase text-gray-600">
                                            13.05.2026 · 20:00
                                        </span>
                                    </div>
                                </div>
                            ) : (
                                <a
                                    href={`/product/${product.slug}`}
                                    class="block relative aspect-square overflow-hidden bg-black border border-white/5"
                                >
                                    <img
                                        src={getProductImageUrl(
                                            Array.isArray(product.images) && product.images.length > 0
                                                ? String(product.images[0])
                                                : null
                                        )}
                                        alt={product.name}
                                        loading="lazy"
                                        transition:name={`image-${product.id}`}
                                        class="w-full h-full object-cover transition-all duration-700 ease-in-out group-hover:scale-110"
                                    />

                                    {product.status === "available" && (
                                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                                            <span class="border border-white px-6 py-2 text-white text-xs uppercase tracking-[0.2em] backdrop-blur-sm">
                                                Ver Obra
                                            </span>
                                        </div>
                                    )}
                                </a>
                            )}

                            <div class="flex justify-between items-start pt-2 relative z-10">
                                <div class="space-y-1">
                                    <h3 class="text-xl text-white font-medium uppercase tracking-wide group-hover:text-gray-300 transition flex items-center gap-3 flex-wrap">
                                        {isLocked ? `Pieza nº ${pieceNumber}` : product.name}

                                        {isLocked && (
                                            <span class="border border-red-900/40 bg-red-900/10 text-red-500 px-2 py-1 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap">
                                                Locked
                                            </span>
                                        )}
                                        {!isLocked && product.status === "sold" && (
                                            <span data-status-badge class="border border-red-900/30 bg-red-900/10 text-red-500 px-2 py-1 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap">
                                                Sold Out
                                            </span>
                                        )}
                                        {!isLocked && product.is_new && (
                                            <span class="bg-red-600 text-white text-[9px] font-bold px-1.5 py-0.5 rounded uppercase tracking-widest whitespace-nowrap animate-pulse shadow-[0_0_8px_rgba(220,38,38,0.8)]">
                                                New
                                            </span>
                                        )}
                                    </h3>
                                    <p class="text-xs text-gray-500 uppercase tracking-wider line-clamp-1">
                                        {isLocked
                                            ? "Revelacion oficial · 13 mayo 2026 · 20:00 CET"
                                            : product.description}
                                    </p>
                                </div>
                                <div class="text-right">
                                    {isLocked ? (
                                        <span class="block text-sm text-white/60 font-bold tracking-widest uppercase whitespace-nowrap">
                                            ?? €
                                        </span>
                                    ) : (product as any).category_hide_price ? (
                                        <span class="block text-sm text-white font-bold tracking-widest uppercase whitespace-nowrap">
                                            {(product as any).category_price_label || "Commission"}
                                        </span>
                                    ) : product.status === "sold" ? (
                                        <span class="block text-sm text-gray-500 font-bold tracking-[0.3em] uppercase whitespace-nowrap line-through decoration-1">
                                            Sold
                                        </span>
                                    ) : (
                                        <span class="block text-xl text-white font-bold tracking-widest">
                                            {formatPrice(product.price_cents, product.currency || "eur")}
                                        </span>
                                    )}
                                </div>
                            </div>
                        </article>
                    );
                })
            }
        </div>

        {list.length === 0 && (
            <div class="text-center py-20">
                <p class="text-gray-500 uppercase tracking-widest">
                    Aun no hay obras publicadas.
                </p>
            </div>
        )}
    </section>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    // Mapa de nombres inyectado desde el frontmatter (BD). Si Susana
    // crea una categoria nueva en /admin → Categorias, aparece aqui
    // tras el siguiente rebuild.
    const CATEGORY_NAMES: Record<string, string> = JSON.parse(
        document.getElementById("category-names-data")?.textContent || "{}"
    );

    function formatCountdown(target: number): { d: string; h: string; m: string; s: string; done: boolean } {
        const diff = target - Date.now();
        if (diff <= 0) return { d: "0", h: "00", m: "00", s: "00", done: true };
        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);
        return {
            d: String(d),
            h: String(h).padStart(2, "0"),
            m: String(m).padStart(2, "0"),
            s: String(s).padStart(2, "0"),
            done: false,
        };
    }

    function startCountdowns() {
        const items = document.querySelectorAll<HTMLElement>('.product-item[data-locked="1"]');
        if (items.length === 0) return;

        const update = () => {
            let anyDone = false;
            items.forEach((el) => {
                const target = el.dataset.revealAt;
                const wrap = el.querySelector<HTMLElement>("[data-countdown]");
                if (!target || !wrap) return;
                const t = new Date(target).getTime();
                const c = formatCountdown(t);
                const cells = {
                    d: wrap.querySelector<HTMLElement>('[data-cd="d"]'),
                    h: wrap.querySelector<HTMLElement>('[data-cd="h"]'),
                    m: wrap.querySelector<HTMLElement>('[data-cd="m"]'),
                    s: wrap.querySelector<HTMLElement>('[data-cd="s"]'),
                };
                if (c.done) {
                    anyDone = true;
                    if (cells.d) cells.d.textContent = "00";
                    if (cells.h) cells.h.textContent = "00";
                    if (cells.m) cells.m.textContent = "00";
                    if (cells.s) cells.s.textContent = "LIVE";
                } else {
                    if (cells.d) cells.d.textContent = c.d.padStart(2, "0");
                    if (cells.h) cells.h.textContent = c.h;
                    if (cells.m) cells.m.textContent = c.m;
                    if (cells.s) cells.s.textContent = c.s;
                }
            });
            if (anyDone) {
                // Si ya paso la hora, recargamos para que el SSR/cliente
                // reciba la vista sin enmascarar.
                setTimeout(() => location.reload(), 1500);
            }
        };

        update();
        const id = window.setInterval(update, 1000);
        document.addEventListener("astro:before-swap", () => clearInterval(id), { once: true });
    }

    document.addEventListener("astro:page-load", async () => {
        startCountdowns();
        // --- Filtro por categoria desde ?category= ---
        const params = new URLSearchParams(window.location.search);
        const filterCat = params.get("category");
        const grid = document.getElementById("product-grid");
        if (filterCat && grid) {
            const items = Array.from(
                document.querySelectorAll<HTMLElement>(".product-item"),
            );
            let visibleCount = 0;
            items.forEach((item) => {
                if (item.dataset.category === filterCat) {
                    item.style.display = "";
                    visibleCount++;
                } else {
                    item.style.display = "none";
                }
            });

            // Re-ordenar los visibles por precio descendente (mas caro primero).
            // Si la categoria oculta precio, manten orden de creacion.
            const visibles = items.filter((it) => it.style.display !== "none");
            visibles.sort((a, b) => {
                const pa = parseInt(a.dataset.price ?? "0", 10);
                const pb = parseInt(b.dataset.price ?? "0", 10);
                return pb - pa;
            });
            visibles.forEach((el) => grid.appendChild(el));

            // Actualizar header con el nombre de la coleccion
            const eyebrow = document.getElementById("category-eyebrow");
            const title = document.getElementById("shop-title");
            const showAll = document.getElementById("show-all-link");
            const catName = CATEGORY_NAMES[filterCat] || filterCat;
            if (eyebrow) {
                eyebrow.textContent = `Colección ${catName}`;
                eyebrow.classList.remove("hidden");
            }
            if (title) {
                title.textContent = catName.toUpperCase();
            }
            if (showAll) {
                showAll.classList.remove("hidden");
            }

            // Si no hay productos en la categoria, mostrar mensaje
            if (visibleCount === 0) {
                const grid = document.getElementById("product-grid");
                if (grid) {
                    const empty = document.createElement("p");
                    empty.className =
                        "text-gray-500 text-xs uppercase tracking-widest text-center py-20 col-span-full";
                    empty.textContent = "No hay obras en esta colección aún.";
                    grid.appendChild(empty);
                }
            }
        }

        // --- Refresh stock client-side (sin rebuild necesario) ---
        // Si Susana marca un cuadro como sold, se ve aqui en segundos.
        try {
            const { data } = await supabase
                .from("products_public")
                .select("id, status")
                .in("status", ["available", "sold", "reserved"]);

            if (data) {
                document.querySelectorAll<HTMLElement>(".product-item").forEach((el) => {
                    const id = el.dataset.productId;
                    const fresh = data.find((p) => p.id === id);
                    if (!fresh) return;
                    const badge = el.querySelector("[data-status-badge]");

                    if (fresh.status === "sold" && !badge) {
                        const h3 = el.querySelector("h3");
                        if (h3) {
                            const span = document.createElement("span");
                            span.dataset.statusBadge = "true";
                            span.className =
                                "border border-red-900/30 bg-red-900/10 text-red-500 px-2 py-1 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap";
                            span.textContent = "Sold Out";
                            h3.appendChild(span);
                        }
                    } else if (fresh.status === "available" && badge) {
                        badge.remove();
                    }
                });
            }
        } catch (err) {
            console.warn("Stock refresh fallo:", err);
        }
    });
</script>
