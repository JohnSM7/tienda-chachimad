---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Pedido confirmado · MADCRY Studio"
    description="Gracias por adquirir una pieza original de Madcry Studio."
    noindex={true}
>
    <main
        class="min-h-screen flex flex-col justify-center items-center px-6 text-center pt-20"
    >
        <div id="loading-state" class="space-y-4">
            <div class="w-12 h-12 border-2 border-white/20 border-t-white rounded-full animate-spin mx-auto"></div>
            <p class="text-gray-400 text-xs uppercase tracking-[0.3em]">Verificando pago...</p>
        </div>

        <div id="success-state" class="hidden">
            <div class="mb-8 relative">
                <div class="absolute inset-0 bg-green-500 blur-xl opacity-20 animate-pulse"></div>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-24 h-24 text-white relative z-10">
                    <path stroke-linecap="square" stroke-linejoin="miter" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>

            <h1 class="text-4xl md:text-6xl font-bold uppercase tracking-tighter text-white mb-4">
                Pedido Confirmado
            </h1>

            <p class="text-gray-400 text-sm md:text-base tracking-wide max-w-md mb-2">
                Gracias por adquirir <span id="product-name" class="text-white font-bold"></span>.
            </p>
            <p class="text-gray-500 text-xs uppercase tracking-[0.2em] mb-12">
                Hemos enviado el recibo a <span id="customer-email" class="text-gray-300"></span>
            </p>

            <div class="p-6 border border-white/10 bg-zinc-900/30 max-w-sm w-full mb-12 backdrop-blur-sm">
                <p class="text-[10px] text-gray-500 uppercase tracking-widest mb-2">Siguientes pasos</p>
                <ul class="text-left space-y-4 text-sm text-gray-300 font-light">
                    <li class="flex items-start gap-3"><span class="text-green-500 mt-1">1.</span><span>Prepararemos tu obra con embalaje de seguridad (24-48h).</span></li>
                    <li class="flex items-start gap-3"><span class="text-green-500 mt-1">2.</span><span>Recibiras un email con el numero de seguimiento.</span></li>
                    <li class="flex items-start gap-3"><span class="text-green-500 mt-1">3.</span><span>Entrega estimada: 3-5 dias laborables.</span></li>
                </ul>
            </div>

            <a href="/" class="px-8 py-3 bg-white text-black font-bold uppercase tracking-[0.2em] text-xs hover:bg-gray-200 transition">
                Volver al inicio
            </a>
        </div>

        <div id="error-state" class="hidden text-center max-w-md">
            <h1 class="text-4xl font-bold uppercase tracking-tighter text-white mb-4">Algo no cuadra</h1>
            <p id="error-message" class="text-gray-400 text-sm mb-8">No hemos podido verificar tu pago.</p>
            <a href="/shop" class="px-8 py-3 border border-white text-white text-xs uppercase tracking-[0.2em] hover:bg-white hover:text-black transition">
                Volver a la tienda
            </a>
        </div>
    </main>
</Layout>

<script>
    document.addEventListener("astro:page-load", async () => {
        const params = new URLSearchParams(window.location.search);
        const sessionId = params.get("session_id");

        const loading = document.getElementById("loading-state");
        const success = document.getElementById("success-state");
        const errorState = document.getElementById("error-state");
        const errorMessage = document.getElementById("error-message");

        const showError = (msg: string) => {
            loading?.classList.add("hidden");
            success?.classList.add("hidden");
            errorState?.classList.remove("hidden");
            if (errorMessage) errorMessage.textContent = msg;
        };

        if (!sessionId) {
            showError("No hay sesion de pago en la URL.");
            return;
        }

        try {
            const url = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/verify-session?session_id=${encodeURIComponent(sessionId)}`;
            const res = await fetch(url, {
                headers: { Authorization: `Bearer ${import.meta.env.PUBLIC_SUPABASE_ANON_KEY}` },
            });
            const data = await res.json();

            if (!res.ok || !data.paid) {
                showError(data.error || "El pago aun no se ha completado.");
                return;
            }

            // Mostrar info real
            const productName = document.getElementById("product-name");
            const customerEmail = document.getElementById("customer-email");
            if (productName && data.product?.name) productName.textContent = data.product.name;
            if (customerEmail && data.customer_email) customerEmail.textContent = data.customer_email;

            loading?.classList.add("hidden");
            success?.classList.remove("hidden");
        } catch (e) {
            showError(e instanceof Error ? e.message : "Error verificando pago.");
        }
    });
</script>
